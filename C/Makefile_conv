#conv系プログラム用Makefile
# 使い方
#   1)ライブラリ及びmainプログラム全て(v_convで始まるもの)のmakeを行う
#     make -f Makefile_conv all
#
#   2)ライブラリだけmakeを行う
#     make -f Makefile_conv
#
#   3)正規ＰＧ以外(v_convで始まらない)
#     make -f Makefile_conv


CFLAGS += -std=c99 -Wall -g3 -O2

LDFLAGS = -L./
LDLIBS = -lCOBconv

COBconv.o : COBconv.h
libCOBconv.a : COBconv.o
	ar rv libCOBconv.a COBconv.o

all : $(basename $(wildcard v_conv_*.c))

% : %.c libCOBconv.a COBconv.h
	$(CC) $(CFLAGS) $(CPPFLAGS) $< $(LDFLAGS) $(LDLIBS) -o $@

