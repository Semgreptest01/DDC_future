#------------------------------------------------------------------------#
# Shell-id        : hnad
# Shell-名        : hnad.src
# 機能            : ＤＤＣ返品コスト削減
#                 : 更新共通シェル変数定義（本番用）
# 作成者          : O.Ogawara
# 作成日          : 2009/10/14
# 修正履歴        : 
# No 修正日付     修正者     修正内容
#  1 2025/12/01   H.Saito    LMDC移行対応
#  2 2025/12/01   R.Someya   LMDC移行対応：ファイルストレージ対応
#------------------------------------------------------------------------#
alias rm 'rm -f'
#------------------------------------------------------------------------#
#       ＯＲＡＣＬＥ関係環境変数
#------------------------------------------------------------------------#
setenv PATH /usr/bin:/etc:/usr/sbin:/usr/ucb:$HOME/bin:/usr/bin/X11:/sbin:/usr/java14/bin:.
setenv ORACLE_BASE /opt/oracle
setenv ORACLE_HOME $ORACLE_BASE/instantclient_19_28
setenv NLS_LANG Japanese_Japan.JA16SJISTILDE
setenv ORACLE_SID LEWP4A
#setenv PATH $ORACLE_HOME:$PATH
setenv PATH ${ORACLE_HOME}:$PATH
#------------------------------------------------------------------------#
#      環境用共通設定
#------------------------------------------------------------------------#
set PROD_DIR = "/prod"
set RDWKDIR = "$PROD_DIR/wk001/hnad/dat"
set BKUPDIR = "$PROD_DIR/wk001/hnad/dat"
set IODIR   = "$PROD_DIR/wk001/hnad/dat"
set WKDIR   = "$PROD_DIR/wk001/hnad/dat"
#------------------------------------------------------------------------#
#      JCLディレクトリ
#------------------------------------------------------------------------#
set JCLDIR="$PROD_DIR/jcl"
#------------------------------------------------------------------------#
#      ログディレクトリ
#------------------------------------------------------------------------#
set LOG_DIR="$PROD_DIR/wk001/hnad/log"
#------------------------------------------------------------------------#
#      モジュールディレクトリ
#------------------------------------------------------------------------#
set PGMDIR="$PROD_DIR/bin"
#------------------------------------------------------------------------#
#      Perlディレクトリ
#------------------------------------------------------------------------#
setenv PERLDIR "$PROD_DIR/perl"
#------------------------------------------------------------------------#
#      DBデータ定義ディレクトリ
#------------------------------------------------------------------------#
set CTLDIR = $PROD_DIR/ora/ctl
set SQLDIR = $PROD_DIR/ora
set EXPORT_DIR = $PROD_DIR/ora/export
set IMPORT_DIR = $PROD_DIR/ora/import
set PLSQLDIR   = $PROD_DIR/ora/plsql

#------------------------------------------------------------------------#
#      パラメータ変数セット(ORACL)
#------------------------------------------------------------------------#
set ORAUID=$1                             # オラクル・ユーザーID
set ORAUIDL=6                             # オラクル・ユーザーID レングス
set ORAPWD=$2                             # オラクル・パスワード
set ORAPWDL=8                             # オラクル・パスワード レングス
#------------------------------------------------------------------------#
#      オラクルユーザーID・PWD環境変数設定
#------------------------------------------------------------------------#
setenv ORAUID  $ORAUID
setenv ORAUIDL $ORAUIDL
setenv ORAPWD  $ORAPWD
setenv ORAPWDL $ORAPWDL
#------------------------------------------------------------------------#
#   その他オラクル関連設定
#------------------------------------------------------------------------#
set SQL_NAME   = "sqlplus"
set DRCTL_DIR  = "$PROD_DIR/ora/ctl"
set ORAOUT_DIR = "HNAD_DAT1"
#------------------------------------------------------------------------#
#  オラクルファイルストレージ関連
#------------------------------------------------------------------------#
set DBOBJDAT = DIRHNADDAT #フラットファイル用ディレクトリオブジェクト名
set DBOBJDMP = DIRHNADDMP #データポンプダンプ用ディレクトリオブジェクト名
set DBDATDIR = /fss/data/hnad/dat #フラットファイル用ファイルストレージパス
set DBDMPDIR = /fss/data/hnad/dmp #データポンプダンプ用ファイルストレージパス
#------------------------------------------------------------------------#
#  ＯＣＩオブジェクトストレージ関連
#------------------------------------------------------------------------#
#LMDC移行 2025.11.21 Start
#set BUCKETNAME  = "loci-xq-prd01-MBHanyoBatBackUp"		# 本番環境
set BUCKETNAME  = "loci-xq-stg01-STHanyoBatBackUp"		# 検証環境
#LMDC移行 2025.11.21 End
#------------------------------------------------------------------------#
#      その他設定
#------------------------------------------------------------------------#
#set FTPASSTYPE = "MB"
#unalias rm
#unalias cp
#------------------------------------------------------------------------#
#  IFP接頭辞
#------------------------------------------------------------------------#
#set IFTYPE   = "MB" # 本番環境
set IFTYPE   = "ST" # 検証環境

