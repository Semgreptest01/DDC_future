# ホームディレクトリを定義
##
##

#LMDC移行## ログ処理変更 START
# 走行ログの記録
#LMDC移行#echo "${PROD_DIR}/LOG/LOG.$(basename $0).$(date +%Y%m%d%H%M%S).$$" > /dev/null
#LMDC移行#exec 2> ${PROD_DIR}/LOG/LOG.$(basename $0).$(date +%Y%m%d%H%M%S).$$
exec 2> /dev/null
source ${PROD_DIR}/SHELL/OUTLOG.INI
exec 2> ${LOG_FILE}
#LMDC移行## ログ処理変更 END

########################
# 変数の定義
########################
tmp=${PROD_DIR}/tmp/$$
today=$(date +%Y%m%d)
yobi=$(v_ldate $today | v_choosecol 2)
datad=${BKUP_DIR}
# A系の正かどうか（ストレージを使えるかどうか）
#LMDC移行#host=0
#LMDC移行#[ $(v_server_ctrl.pl -host $HOSTNAME -print msflg) = "M" -a $(v_server_ctrl.pl -host $HOSTNAME -print job) = "odan_a" ] && host=1
host=1


# /tmp 下の1日以上前の一時ファイルを消す  : プロセスID-* の形式のものを消去
cd ${PROD_DIR}/tmp
find . -mtime +0 -name '[0-9]*-*' -type f -exec rm -f {} \;


#LMDC移行## JP1対応　不要処理コメントアウト START
# ${PROD_DIR}/JOB_CTRL : 10日以上前のジョブＣＴＲＬは消去する。
#LMDC移行#cd ${PROD_DIR}/JOB_CTRL
#LMDC移行#find . -mtime +9 -type f -exec rm -f {} \;
#LMDC移行## JP1対応　不要処理コメントアウト END


# ${PROD_DIR}/LOG/MESSAGES_APL : バックアップファイルを作成し、0バイトにする
cat ${PROD_DIR}/LOG/MESSAGES_APL >> ${PROD_DIR}/LOG/MESSAGES_APL.$today
:> ${PROD_DIR}/LOG/MESSAGES_APL


#LMDC移行## JP1対応　不要処理コメントアウト START
# ${PROD_DIR}/LOG/UPCNT
#LMDC移行#if [ $yobi = "7" ]; then
#LMDC移行#  :> ${PROD_DIR}/LOG/UPCNT
#LMDC移行#fi
#LMDC移行## JP1対応　不要処理コメントアウト END


# ${PROD_DIR}/LOG : 1日以上前のログは圧縮する。
cd ${PROD_DIR}/LOG
#LMDC移行## ログ出力変更対応 START
#LMDC移行#find . -mtime +0 -type f | grep "./LOG." | sed '/.gz$/d' | xargs gzip -f
find . -mtime +0 -type f | grep "./*.log.*" | sed '/.gz$/d' | xargs gzip -f
#LMDC移行## ログ出力変更対応 END
# 10日以上前のログは消去する。
find . -mtime +9 -type f -exec rm -f {} \;

#LMDC移行## JP1対応　不要処理コメントアウト START
# ${PROD_DIR}/BACKUP : シェル類とcrontabのバックアップ：100日以上前を削除。
#LMDC移行#cd ${PROD_DIR}/BACKUP
#LMDC移行#find . -mtime +50 -type f -exec rm -f {} \;
#LMDC移行## JP1対応　不要処理コメントアウト END


#LMDC移行## JP1対応　不要処理コメントアウト START
#LMDC移行## lawson ユーザのプロセスはすべてクリアする（当日STARTは残す）
#LMDC移行#kill -9 $(ps aux | awk '$1=="lawson"&&$9!~/^[0-9][0-9]:[0-9][0-9]$/{print $2}' | v_horiarray pk=END)
