## 2015/07/27追加 START
## 返品削減データ
## 35日以上経過したファイルを削除
# 受信(取得)データ
cat << FIN > $tmp-data_hpsg
DT.KINKYUCUT              35
HNT_KEIKAKUSYURYO_DAY     35
HNT_KOSINTUTI             35
HNT_ONLINE_ATESAKI_VENDOR 35
HNW_ATESAKI               35
HNW_ONLINE_ATESAKI_PARAM  35
SCM                       35
ZAIKOSOKUHO_12JISIME      35
HNT_KEIKAKUSYURYO_SYANAI 35
FIN

cat $tmp-data_hpsg |
while read dir kikan ;do
  [ ! -d ${PROD_DIR}/DATA_HPSG/$dir ] && continue
  cd ${PROD_DIR}/DATA_HPSG/$dir
  find . -mtime +$kikan -type f -exec rm -f {} \;
done

# 送信データ
cat << FIN > $tmp-hpsg
EXCEL   35
SENDLOG 35
FIN

cat $tmp-hpsg |
while read dir kikan ;do
  [ ! -d ${PROD_DIR}/HPSG/$dir ] && continue
  cd ${PROD_DIR}/HPSG/$dir
  find . -mtime +$kikan -type f -exec rm -f {} \;
done
## 2015/07/27追加 END

