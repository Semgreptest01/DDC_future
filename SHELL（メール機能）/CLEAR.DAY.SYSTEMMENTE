# 横断集計 古いデータの削除
####################################
# RCVディレクトリ
## バックアップリスト格納ディレクトリ
cd ${PROD_DIR}/RCV/BACKUPLIST
find . -mtime +6 -type f -exec rm -f {} \;


#LMDC移行## JP1対応　不要処理コメントアウト START
#LMDC移行### 受信ジョブＣＴＲＬ格納ディレクトリ
#LMDC移行#cd ${PROD_DIR}/RCV/RCV_JOB_CTRL
#LMDC移行#find . -mtime +6 -type f -exec rm -f {} \;
#LMDC移行## JP1対応　不要処理コメントアウト END



## IFP受信ファイル
## A系正の場合は全ファイルをストレージに移動
## その他の場合は3日以上経過したファイルを削除
cat << FIN > $tmp-rcv_dir
DB 1
MS 1
PL 1
SB 1
UL 1
WB 1
WJ 1
HI 1
FIN

cat $tmp-rcv_dir |
while read dir kikan ;do
  [ ! -d ${PROD_DIR}/RCV/$dir ] && continue;
  cd ${PROD_DIR}/RCV/$dir

  # A系正の場合は全ファイルをストレージに移動
  if [ $host = "1" ]; then
    find . -type f -exec mv -f {} $datad/RCV/$dir/{} \;
#LMDC移行## JP1対応　不要処理コメントアウト START
#LMDC移行#  # その他の場合は3日以上経過したファイルを残し削除
#LMDC移行#  else
#LMDC移行#    find . -mtime +$kikan -type f -exec rm -f {} \;
#LMDC移行# JP1対応　コメントアウト END
