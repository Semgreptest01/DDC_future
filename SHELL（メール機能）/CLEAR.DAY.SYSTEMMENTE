#!/bin/bash -xv
source `dirname $0`/../.bashrc >& /dev/null
#
# CLEAR.DAY.SYSTEMMENTE >> 不要過去ファイルを消去する。(全マシン共通)
# Usage : CLEAR.DAY.SYSTEMMENTE
#
# 17:00に起動
#
# CREATED  BY : vinx 2014/12/15
# MODIFIED BY : vinx 2015/03/13    SA対応にて RCV/HI 消去追加
