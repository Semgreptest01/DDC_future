DB 90
MS 90
PL 90
SB 90
UL 90
WB 90
WJ 90
HI 90
FIN

if [ $host = "1" ]; then
  cat $tmp-data1_dir |
  while read dir kikan ;do
    [ ! -d $datad/RCV/$dir ] && continue;
    cd $datad/RCV/$dir
    find . -mtime +$kikan -type f -exec rm -f {} \;
  done
fi


