#!/bin/bash -xv
source `dirname $0`/../.bashrc >& /dev/null
#
# MAILSEND.DAYHP.KINKYUCUT_RIYOSYA : 緊急カット商品メール配信
#                                   （センター、子ベンダー向け）
#
# CREATED BY : vinx 2014/12/15
# MODIFIED BY : VINX 山本 2025/11/20  LMDC移行：横断集計メール移行対応


# ログの記録
#LMDC移行# Start
#LMDC移行#echo "${PROD_DIR}/LOG/LOG.$(basename $0).$(date +%Y%m%d%H%M%S).$$"
